# Server Environment Settings
PORT=5500
NODE_ENV=development

# Database Settings
# Replace with staging or local connection uri. Do not set credentials in shared repositories.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>

# Security
JWT_SECRET=supersecretjwtkeyforapexbeebusinessoperatingnetwork

# Cloudinary (Optional, leave blank to skip Cloudinary upload fallback)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Feature Flags (true/false)
ENABLE_ATOMIC_CHECKOUT=false
ENABLE_REDIS_OTP=false
ENABLE_REDIS_RATE_LIMIT=false
ENABLE_NEW_WALLET_LEDGER=false
ENABLE_BULLMQ_WORKERS=false
ENABLE_SOCKET_REDIS=false
